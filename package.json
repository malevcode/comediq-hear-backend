{
  "name": "comediq-backend",
  "version": "2.0.0",
  "description": "Comediq API — Cloudflare Workers + D1 + R2 + Durable Objects",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute comediq --file=schema/d1-schema.sql",
    "db:init:remote": "wrangler d1 execute comediq --remote --file=schema/d1-schema.sql",
    "secret:assemblyai": "wrangler secret put ASSEMBLYAI_KEY",
    "secret:anthropic": "wrangler secret put ANTHROPIC_KEY",
    "legacy:start": "node server.js",
    "legacy:dev": "nodemon server.js"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "wrangler": "^3.60.0",
    "@cloudflare/workers-types": "^4.20240725.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
